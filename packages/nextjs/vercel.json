{
  "installCommand": "yarn install",
  "rewrites": [
    {
      "source": "/bounty/:id",
      "destination": "/bounty/placeholder/"
    },
    {
      "source": "/bounty/:id/",
      "destination": "/bounty/placeholder/"
    },
    {
      "source": "/rap-sheet/:address",
      "destination": "/rap-sheet/"
    },
    {
      "source": "/rap-sheet/:address/",
      "destination": "/rap-sheet/"
    }
  ]
}
